# 6d. Regional performance table
print("\nDetailed Regional Performance Table:")
reg_perf = df.groupby('WHO Region').agg(
    Countries=('Country','count'),
    Confirmed=('Confirmed','sum'),
    Deaths=('Deaths','sum'),
    Recovered=('Recovered','sum'),
    Active=('Active','sum'),
    Avg_Mortality=('Mortality Rate (%)','mean'),
    Avg_Recovery=('Recovery Rate (%)','mean'),
    New_Cases_Week=('1 week change','sum'),
).round(2).reset_index()
reg_perf['CFR (%)'] = (reg_perf['Deaths']/reg_perf['Confirmed']*100).round(2)
print(reg_perf[['WHO Region','Countries','Confirmed','Deaths','CFR (%)','Avg_Recovery']].to_string(index=False))
