print("\n\n── STEP 6: ADVANCED ANALYSIS ──────────────────────────")

# 6a. Distribution of Mortality Rate
fig, axes = plt.subplots(1, 3, figsize=(14, 5))

axes[0].hist(df['Mortality Rate (%)'], bins=30, color='#DC2626',
             edgecolor='white', alpha=0.85)
axes[0].axvline(df['Mortality Rate (%)'].mean(), color='navy',
                linestyle='--', linewidth=1.5,
                label=f'Mean: {df["Mortality Rate (%)"].mean():.2f}%')
axes[0].axvline(df['Mortality Rate (%)'].median(), color='orange',
                linestyle='--', linewidth=1.5,
                label=f'Median: {df["Mortality Rate (%)"].median():.2f}%')
axes[0].set_title('Mortality Rate Distribution', fontsize=11, fontweight='bold')
axes[0].set_xlabel('Mortality Rate (%)')
axes[0].legend(fontsize=8)

# 6b. Box plot by WHO Region — Mortality Rate
df.boxplot(column='Mortality Rate (%)', by='WHO Region', ax=axes[1],
           patch_artist=True,
           boxprops=dict(facecolor='#DBEAFE', color='#185FA5'),
           medianprops=dict(color='#DC2626', linewidth=2),
           whiskerprops=dict(color='#185FA5'),
           capprops=dict(color='#185FA5'),
           flierprops=dict(marker='o', color='#185FA5', alpha=0.5, markersize=4))
axes[1].set_title('Mortality Rate by WHO Region', fontsize=11, fontweight='bold')
