axes[1].tick_params(axis='x', rotation=30, labelsize=7)
plt.sca(axes[1])
plt.title('Mortality Rate by WHO Region', fontsize=11, fontweight='bold')

# 6c. New cases vs Confirmed (log scale)
import numpy as np
axes[2].scatter(np.log10(df['Confirmed']+1), df['New cases'],
                c=df['Mortality Rate (%)'], cmap='RdYlGn_r',
                alpha=0.7, s=40, edgecolors='white', linewidth=0.5)
axes[2].set_xlabel('Log10(Confirmed Cases)', fontsize=10)
