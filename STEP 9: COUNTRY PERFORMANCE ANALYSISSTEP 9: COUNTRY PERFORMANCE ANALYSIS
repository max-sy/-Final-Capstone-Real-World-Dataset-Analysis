# Country comparison — top vs bottom recovery
top_recovery = df[df['Confirmed']>1000].nlargest(8,'Recovery Rate (%)')
bot_recovery = df[df['Confirmed']>1000].nsmallest(8,'Recovery Rate (%)')
compare_df   = pd.concat([top_recovery, bot_recovery])
colors_comp  = ['#1D9E75' if v >= 70 else '#DC2626' for v in compare_df['Recovery Rate (%)']]
bars = axes[1].barh(compare_df['Country'], compare_df['Recovery Rate (%)'],
