perf_counts = df['Performance'].value_counts()
print("\nCountry Performance Segments:")
print(perf_counts)

fig, axes = plt.subplots(1, 2, figsize=(13, 6))
colors_perf = {'Good':'#1D9E75','Medium':'#185FA5','Poor':'#D97706','Critical':'#DC2626'}
axes[0].pie(perf_counts.values,
            labels=perf_counts.index,
