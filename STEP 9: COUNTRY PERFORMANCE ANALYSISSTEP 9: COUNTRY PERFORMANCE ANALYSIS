print("\n\n── STEP 9: COUNTRY PERFORMANCE ANALYSIS ──────────────")

# Segment countries
df['Performance'] = 'Medium'
df.loc[df['Recovery Rate (%)'] >= 70, 'Performance']  = 'Good'
